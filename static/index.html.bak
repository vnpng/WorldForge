<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>WorldForge v13.5.1</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body class="bg-[#0b0f19] text-gray-100 font-sans h-screen flex flex-col overflow-hidden">

<div id="app" class="flex h-full relative" :class="{'hide-cot': !showCoT}" v-cloak>

    <transition name="fade">
        <div v-if="toast.show" class="fixed top-5 left-1/2 -translate-x-1/2 bg-green-600 text-white px-6 py-3 rounded-xl shadow-lg z-[100] flex items-center gap-2 border border-green-500">
            <i class="fas fa-check-circle"></i><span>{{ toast.message }}</span>
        </div>
    </transition>

    <div v-if="sidebarOpen" @click="sidebarOpen = false" class="fixed inset-0 bg-black/70 z-30 md:hidden backdrop-blur-sm"></div>

    <aside class="fixed inset-y-0 left-0 z-40 w-72 bg-gray-900 border-r border-gray-800 flex flex-col transition-transform duration-300 md:relative" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full md:translate-x-0'">
        <div class="p-4 border-b border-gray-800 h-16 flex items-center justify-between shrink-0">
            <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500">
                <i class="fas fa-cubes mr-2 text-blue-500"></i>WorldForge
            </h1>
            <button @click="sidebarOpen = false" class="md:hidden text-gray-400 p-2"><i class="fas fa-times"></i></button>
        </div>

        <div class="p-4 flex gap-2 shrink-0 border-b border-gray-800/50">
            <button @click="createNewSession('chat')" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-2 px-2 rounded-lg transition font-medium flex items-center justify-center gap-1 text-sm shadow-lg shadow-blue-900/20">
                <i class="fas fa-comment-dots"></i> 新建会话
            </button>
            <button @click="openRpgForm" class="flex-1 bg-purple-600 hover:bg-purple-700 text-white py-2 px-2 rounded-lg transition font-medium flex items-center justify-center gap-1 text-sm shadow-lg shadow-purple-900/20">
                <i class="fas fa-dice-d20"></i> 新建开局
            </button>
        </div>

        <div class="flex-1 overflow-y-auto px-2 py-2 space-y-1">
            <div v-if="sessions.length === 0" class="text-center text-gray-600 text-xs mt-10">暂无存档记录</div>
            <div v-for="session in sessions" :key="session.id" class="group flex items-center justify-between p-3 rounded-lg cursor-pointer transition-colors border border-transparent" :class="{'bg-gray-800 border-gray-700': currentSessionId === session.id, 'hover:bg-gray-800/50': currentSessionId !== session.id}" @click="handleSessionClick(session.id)">
                <div class="flex items-center flex-1 min-w-0 overflow-hidden">
                    <i v-if="session.type === 'rpg'" class="fas fa-dice-d20 mr-3 shrink-0 transition" :class="currentSessionId === session.id ? 'text-purple-400' : 'text-gray-600 group-hover:text-purple-400'"></i>
                    <i v-else class="fas fa-comment-alt mr-3 shrink-0 transition" :class="currentSessionId === session.id ? 'text-blue-400' : 'text-gray-600 group-hover:text-blue-400'"></i>
                    
                    <div v-if="editingSessionId === session.id" class="flex-1 mr-2">
                        <input v-model="editTempTitle" @blur="saveEditTitle(session)" @keyup.enter="saveEditTitle(session)" class="bg-gray-950 text-white text-sm px-2 py-1 rounded w-full border border-blue-500 outline-none" autofocus @click.stop>
                    </div>
                    <div v-else class="flex flex-col flex-1 min-w-0">
                        <span class="text-sm text-gray-200 truncate font-medium">{{ session.title || '未命名' }}</span>
                        <span class="text-[10px] text-gray-500 mt-0.5">{{ formatDate(session.updatedAt) }}</span>
                    </div>
                </div>
                <div v-if="editingSessionId !== session.id" class="opacity-0 group-hover:opacity-100 flex items-center transition shrink-0">
                    <button @click.stop="startEditTitle(session)" class="p-1.5 text-gray-500 hover:text-blue-400" title="重命名"><i class="fas fa-edit text-xs"></i></button>
                    <button @click.stop="deleteSingleSession(session.id)" class="p-1.5 text-gray-500 hover:text-red-500 ml-1" title="删除"><i class="fas fa-trash-alt text-xs"></i></button>
                </div>
            </div>
        </div>

        <div class="p-4 border-t border-gray-800 bg-gray-900 shrink-0 space-y-2">
            <div class="flex gap-2 mb-1">
                <button @click="exportCurrentSession" class="flex-1 bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-green-400 py-1.5 rounded text-xs border border-gray-700 transition" title="导出会话/存档"><i class="fas fa-file-export mr-1"></i>导出会话/存档</button>
                <label class="flex-1 bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-blue-400 py-1.5 rounded text-xs border border-gray-700 transition cursor-pointer text-center">
                    <i class="fas fa-file-import mr-1"></i>加载会话/存档
                    <input type="file" @change="importSession" class="hidden" accept=".json">
                </label>
            </div>

            <button @click="showPromptEditor = true; sidebarOpen = false" class="flex items-center justify-between text-gray-400 hover:text-yellow-400 transition w-full p-2 rounded-lg hover:bg-gray-800 text-sm">
                <span class="truncate w-40 text-left"><i class="fas fa-scroll mr-2"></i>预设引擎库</span>
                <i class="fas fa-edit text-xs"></i>
            </button>

            <button @click="showAdvSettings = true; sidebarOpen = false" class="flex items-center justify-between text-gray-400 hover:text-purple-400 transition w-full p-2 rounded-lg hover:bg-gray-800 text-sm">
                <span class="truncate w-40 text-left"><i class="fas fa-sliders-h mr-2"></i>引擎高级参数</span>
                <i class="fas fa-chevron-right text-xs"></i>
            </button>
            <button @click="showSettings = true; sidebarOpen = false" class="flex items-center justify-between text-gray-400 hover:text-blue-400 transition w-full p-2 rounded-lg hover:bg-gray-800 text-sm">
                <span class="truncate w-40 text-left"><i class="fas fa-server mr-2"></i>API 节点设置</span>
                <i class="fas fa-cog"></i>
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col w-full h-full relative" :style="currentSession?.type === 'rpg' ? 'background-image: radial-gradient(circle at 50% 0%, #1f2937 0%, transparent 70%);' : 'background: #0f111a;'">
        <header class="md:hidden h-14 bg-gray-900 border-b border-gray-800 flex items-center px-4 justify-between shrink-0">
            <button @click="sidebarOpen = true" class="text-gray-300 p-2 -ml-2"><i class="fas fa-bars text-xl"></i></button>
            <span class="font-bold text-gray-200 truncate text-sm">
                <i :class="currentSession?.type === 'rpg' ? 'fas fa-dice-d20 text-purple-400' : 'fas fa-comment-dots text-blue-400'"></i> {{ currentSession?.title || 'WorldForge' }}
            </span>
            <div class="w-8"></div>
        </header>

        <div id="chat-container" class="flex-1 overflow-y-auto p-4 md:p-6 space-y-6 scroll-smooth flex flex-col items-center">
            <div v-if="!currentSession || visibleMessages.length === 0" class="flex flex-col items-center justify-center h-full text-gray-600 space-y-4">
                <i :class="currentSession?.type === 'rpg' ? 'fas fa-dragon text-5xl text-purple-900/50' : 'fas fa-comments text-5xl text-blue-900/50'"></i>
                <p class="text-sm font-medium">{{ currentSession?.type === 'rpg' ? '模组已加载，请输入你的第一个动作' : '发送消息，开始聊天' }}</p>
                <div class="text-xs bg-gray-800/50 px-3 py-1 rounded-full border border-gray-700/50 text-gray-500">
                    <i class="fas fa-scroll mr-1"></i> 当前引擎核心: {{ currentSession?.type === 'rpg' ? (activeSystemPrompt?.name || '默认') : '通用助手' }}
                 </div>
            </div>

            <div v-for="(msg, index) in visibleMessages" :key="index" class="group flex flex-col gap-1 w-full" :class="msg.role === 'user' ? 'items-end' : 'items-start'">
                <div class="flex items-start gap-2 w-full max-w-[100%] md:max-w-[850px]" :class="msg.role === 'user' ? 'justify-end' : 'justify-start'">
                    
                    <div v-if="msg.role === 'user'" 
                         class="p-3 md:p-4 rounded-2xl shadow-lg text-[15px] text-white rounded-br-none max-w-[85%]" 
                         :class="currentSession?.type === 'rpg' ? 'bubble-user-rpg' : 'bubble-user-chat'">
                        {{ msg.content }}
                    </div>

                    <div v-else class="flex flex-col w-full">
                        <div class="p-4 md:p-6 shadow-xl text-[15px] rounded-bl-none markdown-body break-words w-full transition-all duration-300" 
                             :class="[
                                currentSession?.type === 'rpg' ? 'bubble-rpg' : 'bubble-chat', 
                                {'typing-cursor': msg.isStreaming},
                                {'interrupted-msg': msg.wasInterrupted} 
                             ]">
                            <div v-if="msg.content" v-html="renderMarkdown(msg.content)"></div>
                            
                            <div v-else class="flex gap-2 py-2 items-center text-xs tracking-wider">
                                <span v-if="msg.wasInterrupted" class="text-red-400 flex items-center gap-1">
                                    <i class="fas fa-stop-circle"></i> {{ currentSession?.type === 'rpg' ? '连接中断' : '已中断' }}
                                </span>
                                <span v-else :class="currentSession?.type === 'rpg' ? 'text-purple-400' : 'text-blue-400'" class="flex items-center gap-1">
                                    <i class="fas fa-circle-notch fa-spin"></i> {{ currentSession?.type === 'rpg' ? '引擎推演中...' : '思考中...' }}
                                </span>
                            </div>
                        </div>
                        <div v-if="msg.usage" class="text-[10px] text-gray-500 mt-1.5 flex flex-wrap gap-x-4 gap-y-1 px-2">
                            <span title="你发送的字数"><i class="fas fa-arrow-up text-green-500/70"></i> 你的字数: {{ msg.usage.user_words }}</span>
                            <span title="上下文消耗 Tokens"><i class="fas fa-database text-blue-500/70"></i> 上下文消耗: {{ msg.usage.prompt_tokens }}</span>
                            <span title="AI 回复字数"><i class="fas fa-arrow-down text-purple-500/70"></i> 回复字数: {{ msg.usage.ai_words }}</span>
                            <span title="AI 回复 Tokens"><i class="fas fa-coins text-yellow-500/70"></i> 回复消耗: {{ msg.usage.completion_tokens }}</span>
                        </div>
                    </div>

                    <div class="msg-actions flex flex-col gap-1 pt-2 shrink-0" :class="msg.role === 'user' ? 'order-first pr-2' : 'pl-2'">
                        <button @click="editMessage(msg.originalIndex)" class="p-2 bg-gray-800 text-gray-400 hover:text-white rounded-full transition" title="编辑并截断"><i class="fas fa-edit text-xs"></i></button>
                        <button @click="copyMessage(msg.content)" class="p-2 bg-gray-800 text-gray-400 hover:text-green-400 rounded-full transition" title="复制内容"><i class="fas fa-copy text-xs"></i></button>
                        <button v-if="msg.role === 'assistant'" @click="regenerateMessage(msg.originalIndex)" class="p-2 bg-gray-800 text-gray-400 hover:text-blue-400 rounded-full transition" title="重新生成此回复"><i class="fas fa-sync-alt text-xs"></i></button>
                        <button @click="deleteMessage(msg.originalIndex)" class="p-2 bg-gray-800 text-gray-400 hover:text-red-400 rounded-full transition" title="删除此条"><i class="fas fa-trash text-xs"></i></button>
                    </div>
                </div>
            </div>
            <div class="h-2"></div>
        </div>

        <div class="bg-gray-900 border-t border-gray-800 p-3 md:p-4 shrink-0 z-20 shadow-[0_-5px_20px_rgba(0,0,0,0.3)] w-full">
            <div class="max-w-[850px] mx-auto flex flex-col gap-2">
                
                <div class="flex items-center gap-3 px-1 min-h-[28px]">
                    <button @click="enableStream = !enableStream" 
                            class="text-[11px] font-medium py-1.5 px-3 rounded-lg border transition-all flex items-center gap-2"
                            :class="enableStream ? 'bg-green-500/10 text-green-400 border-green-500/30 hover:bg-green-500/20' : 'bg-gray-800 text-gray-500 border-gray-700 hover:text-gray-400'">
                        <div class="w-2 h-2 rounded-full shadow-[0_0_5px_currentColor]" :class="enableStream ? 'bg-green-500' : 'bg-gray-500'"></div>
                        流式输出
                    </button>

                    <button v-if="currentSession?.type === 'rpg'" @click="addCoreMemory" class="text-[11px] bg-purple-900/20 hover:bg-purple-900/40 text-purple-300 hover:text-purple-200 py-1.5 px-3 rounded-lg border border-purple-500/30 transition flex items-center gap-1.5 group">
                        <i class="fas fa-thumbtack group-hover:rotate-45 transition-transform"></i> 注入核心记忆
                    </button>
                </div>

                <div class="flex items-end gap-2 transition-all">
                    <div class="flex-1 relative bg-gray-950 rounded-xl border border-gray-700 flex items-end p-2 gap-2 shadow-inner" :class="currentSession?.type === 'rpg' ? 'focus-within:border-purple-500' : 'focus-within:border-blue-500'">
                        <textarea ref="inputRef" v-model="input" rows="1" @input="autoResize" @keydown.enter.prevent="handleEnter" :placeholder="currentSession?.type === 'rpg' ? '输入行动/数字/数字组合... (Enter 发送)' : '发点什么... (Enter 发送)'" class="flex-1 bg-transparent text-gray-100 pl-3 py-2 focus:outline-none resize-none max-h-40 overflow-y-auto text-sm md:text-base leading-relaxed"></textarea>
                    </div>
                    
                    <button v-if="isLoading" @click="stopGeneration" class="mb-1 p-3 rounded-lg bg-red-900/50 text-red-400 hover:bg-red-600 hover:text-white transition shrink-0"><i class="fas fa-stop"></i></button>
                    <button v-else @click="sendMessage" :disabled="!input.trim()" class="mb-1 p-3 rounded-lg text-white disabled:bg-gray-800 disabled:text-gray-600 transition shrink-0" :class="currentSession?.type === 'rpg' ? 'bg-purple-600 hover:bg-purple-500' : 'bg-blue-600 hover:bg-blue-500'"><i class="fas fa-paper-plane"></i></button>

                    <button @click="scrollToBottom(true)" class="mb-1 p-3 rounded-lg bg-purple-600/20 text-purple-400 hover:bg-purple-600 hover:text-white transition shrink-0 border border-purple-500/30" title="回到底部">
                        <i class="fas fa-arrow-down"></i>
                    </button>

                </div>

            </div>
        </div>
    </main>
    
    <div v-if="showPromptEditor" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-gray-900 p-0 rounded-2xl w-full max-w-5xl h-[90vh] flex flex-col border border-gray-700 shadow-2xl overflow-hidden">
            <div class="p-4 border-b border-gray-800 bg-gray-950 flex justify-between items-center shrink-0">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-scroll text-yellow-500"></i> System Prompt 预设引擎库
                </h2>
                <button @click="showPromptEditor = false" class="text-gray-500 hover:text-red-500"><i class="fas fa-times text-xl"></i></button>
            </div>
            
            <div class="flex flex-1 overflow-hidden">
                <div class="w-64 bg-gray-900 border-r border-gray-800 flex flex-col">
                    <div class="p-3 border-b border-gray-800">
                        <button @click="addNewSystemPrompt" class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded-lg text-sm font-bold transition flex items-center justify-center gap-2">
                            <i class="fas fa-plus"></i> 新建预设
                        </button>
                    </div>
                    <div class="flex-1 overflow-y-auto p-2 space-y-1">
                        <div v-for="prompt in systemPrompts" :key="prompt.id" 
                             class="p-3 rounded-lg cursor-pointer transition flex items-center justify-between group"
                             :class="activeSystemPromptId === prompt.id ? 'bg-gray-800 border border-yellow-600/50' : 'hover:bg-gray-800 border border-transparent'"
                             @click="activeSystemPromptId = prompt.id">
                            <span class="text-sm text-gray-200 truncate font-medium">{{ prompt.name }}</span>
                            <div class="opacity-0 group-hover:opacity-100 transition">
                                <button v-if="systemPrompts.length > 1" @click.stop="deleteSystemPrompt(prompt.id)" class="text-gray-500 hover:text-red-500"><i class="fas fa-trash text-xs"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex-1 flex flex-col bg-[#131318]">
                    <div class="p-4 border-b border-gray-800 flex gap-4 items-center bg-gray-900/50">
                        <div class="flex-1">
                            <label class="text-xs text-gray-500 block mb-1">预设名称</label>
                            <input v-if="activeSystemPrompt" v-model="activeSystemPrompt.name" class="w-full bg-transparent border-b border-gray-700 text-white font-bold text-lg focus:outline-none focus:border-yellow-500 py-1">
                        </div>
                        <div class="text-xs text-gray-500 text-right">
                             <div class="mb-1"><i class="fas fa-info-circle text-blue-400"></i> 提示：</div>
                             下次新建对话时生效
                        </div>
                    </div>
                    <div class="flex-1 relative">
                         <textarea v-if="activeSystemPrompt" v-model="activeSystemPrompt.content" class="w-full h-full bg-[#131318] text-gray-300 p-4 font-mono text-sm focus:outline-none resize-none leading-relaxed" spellcheck="false"></textarea>
                         <div v-else class="flex items-center justify-center h-full text-gray-500">请选择或新建一个预设</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
    <div v-if="showRpgForm" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-gray-900 p-0 rounded-2xl w-full max-w-4xl max-h-[95vh] flex flex-col border border-gray-700 shadow-2xl overflow-hidden">
            <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-gray-950 shrink-0">
                <h2 class="text-xl font-bold text-white flex items-center gap-2"><i class="fas fa-globe text-purple-600"></i> 创建无限世界</h2>
                <button @click="showRpgForm = false" class="text-gray-500 hover:text-red-500"><i class="fas fa-times text-xl"></i></button>
            </div>
            
            <div class="bg-blue-900/20 px-6 py-4 border-b border-blue-900/30 flex flex-col md:flex-row items-center gap-4">
                <div class="flex flex-1 items-center gap-2 w-full">
                    <label class="text-xs text-blue-300 font-bold shrink-0 whitespace-nowrap"><i class="fas fa-microchip"></i> 搭载引擎:</label>
                    <select v-model="activeSystemPromptId" class="flex-1 bg-gray-800 border border-gray-600 text-white text-xs rounded px-2 py-1.5 focus:border-blue-500 outline-none">
                        <option v-for="prompt in systemPrompts" :key="prompt.id" :value="prompt.id">{{ prompt.name }}</option>
                    </select>
                </div>
                <div class="flex flex-1 items-center gap-2 w-full">
                    <label class="text-xs text-purple-300 font-bold shrink-0 whitespace-nowrap"><i class="fas fa-database"></i> 内容随机库:</label>
                    <select v-model="activeRandomTheme" class="flex-1 bg-gray-800 border border-gray-600 text-white text-xs rounded px-2 py-1.5 focus:border-purple-500 outline-none">
                        <option v-for="theme in Object.keys(themeLibs)" :key="theme" :value="theme">{{ theme }}</option>
                    </select>
                </div>
                <button @click="randomAll" class="w-full md:w-auto px-4 py-1.5 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white text-xs font-bold rounded-lg shadow-lg transition flex items-center justify-center gap-2">
                    <i class="fas fa-dice"></i> 全部随机
                </button>
            </div>

            <div class="p-6 overflow-y-auto flex-1 space-y-6 text-gray-200">
                <div class="space-y-2">
                    <label class="font-bold text-sm flex items-center gap-2 text-green-400"><span class="text-red-500">*</span><i class="fas fa-globe-americas"></i> 世界观设定</label>
                    <div class="flex gap-2 items-center">
                        <textarea v-model="rpgForm.world" :disabled="rpgLocks.world" :class="{'opacity-50 bg-gray-900 cursor-not-allowed': rpgLocks.world}" placeholder="修仙世界, 赛博朋克..." class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none min-h-[60px] transition-all"></textarea>
                        <button @click="randomInput('world')" :disabled="rpgLocks.world" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 hover:text-purple-400 rounded-lg transition disabled:opacity-30 flex items-center justify-center" title="随机生成"><i class="fas fa-dice"></i></button>
                        <button @click="rpgLocks.world = !rpgLocks.world" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.world ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500 hover:text-white'">
                            <i class="fas" :class="rpgLocks.world ? 'fa-lock' : 'fa-lock-open'"></i>
                        </button>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="font-bold text-sm flex items-center gap-2 text-yellow-500"><i class="fas fa-balance-scale"></i> 附加规则/特殊设定/核心天赋/特质</label>
                    <div class="flex gap-2 items-center">
                        <textarea v-model="rpgForm.rules" :disabled="rpgLocks.rules" :class="{'opacity-50 bg-gray-900 cursor-not-allowed': rpgLocks.rules}" placeholder="例如：物理定律失效，灵气由情绪产生..." class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none min-h-[50px] transition-all"></textarea>
                        <button @click="rpgLocks.rules = !rpgLocks.rules" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.rules ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500 hover:text-white'">
                            <i class="fas" :class="rpgLocks.rules ? 'fa-lock' : 'fa-lock-open'"></i>
                        </button>
                    </div>
                </div>

                <div class="border-t border-gray-800 my-4"></div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>姓名</label>
                        <div class="flex gap-2 items-center">
                            <input v-model="rpgForm.name" :disabled="rpgLocks.name" :class="{'opacity-50 bg-gray-900': rpgLocks.name}" class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:border-purple-500 outline-none transition-all">
                            <button @click="randomInput('name')" :disabled="rpgLocks.name" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg disabled:opacity-30 transition flex items-center justify-center"><i class="fas fa-dice"></i></button>
                            <button @click="rpgLocks.name = !rpgLocks.name" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.name ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.name ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>身份/职业</label>
                        <div class="flex gap-2 items-center">
                            <input v-model="rpgForm.identity" :disabled="rpgLocks.identity" :class="{'opacity-50 bg-gray-900': rpgLocks.identity}" class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:border-purple-500 outline-none transition-all">
                            <button @click="randomInput('identity')" :disabled="rpgLocks.identity" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg disabled:opacity-30 transition flex items-center justify-center"><i class="fas fa-dice"></i></button>
                            <button @click="rpgLocks.identity = !rpgLocks.identity" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.identity ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.identity ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>性别</label>
                        <div class="flex gap-2 items-center">
                            <select v-model="rpgForm.gender" :disabled="rpgLocks.gender" :class="{'opacity-50 bg-gray-900': rpgLocks.gender}" class="flex-1 h-10 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:border-purple-500 outline-none appearance-none cursor-pointer">
                                <option v-for="opt in (themeLibs[activeRandomTheme]?.gender || [])" :key="opt" :value="opt">{{ opt }}</option>
                            </select>
                            <button @click="rpgLocks.gender = !rpgLocks.gender" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.gender ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.gender ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>种族</label>
                        <div class="flex gap-2 items-center">
                            <select v-model="rpgForm.race" :disabled="rpgLocks.race" :class="{'opacity-50 bg-gray-900': rpgLocks.race}" class="flex-1 h-10 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:border-purple-500 outline-none appearance-none cursor-pointer">
                                <option v-for="opt in (themeLibs[activeRandomTheme]?.race || [])" :key="opt" :value="opt">{{ opt }}</option>
                            </select>
                            <button @click="rpgLocks.race = !rpgLocks.race" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.race ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.race ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>年龄 (1-99)</label>
                        <div class="flex gap-2 items-center">
                            <input v-model="rpgForm.age" :disabled="rpgLocks.age" :class="{'opacity-50 bg-gray-900': rpgLocks.age}" class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:border-purple-500 outline-none">
                            <button @click="randomInput('age')" :disabled="rpgLocks.age" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg disabled:opacity-30 transition flex items-center justify-center"><i class="fas fa-dice"></i></button>
                            <button @click="rpgLocks.age = !rpgLocks.age" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.age ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.age ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1">文风增强</label>
                        <div class="flex gap-2 items-center">
                            <select v-model="rpgForm.style" :disabled="rpgLocks.style" :class="{'opacity-50 bg-gray-900': rpgLocks.style}" class="flex-1 h-10 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:border-purple-500 outline-none appearance-none cursor-pointer">
                                <option v-for="opt in (themeLibs[activeRandomTheme]?.style || [])" :key="opt" :value="opt">{{ opt }}</option>
                            </select>
                            <button @click="rpgLocks.style = !rpgLocks.style" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.style ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.style ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>外貌/身材</label>
                        <div class="flex gap-2 items-center">
                            <textarea v-model="rpgForm.appearance" :disabled="rpgLocks.appearance" :class="{'opacity-50 bg-gray-900': rpgLocks.appearance}" class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none min-h-[60px]"></textarea>
                            <button @click="randomInput('appearance')" :disabled="rpgLocks.appearance" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg transition disabled:opacity-30 flex items-center justify-center"><i class="fas fa-dice"></i></button>
                            <button @click="rpgLocks.appearance = !rpgLocks.appearance" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.appearance ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.appearance ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-purple-400 flex items-center gap-1"><span class="text-red-500">*</span>性格</label>
                        <div class="flex gap-2 items-center">
                            <textarea v-model="rpgForm.personality" :disabled="rpgLocks.personality" :class="{'opacity-50 bg-gray-900': rpgLocks.personality}" class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none min-h-[60px]"></textarea>
                            <button @click="randomInput('personality')" :disabled="rpgLocks.personality" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg transition disabled:opacity-30 flex items-center justify-center"><i class="fas fa-dice"></i></button>
                            <button @click="rpgLocks.personality = !rpgLocks.personality" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.personality ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.personality ? 'fa-lock' : 'fa-lock-open'"></i></button>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-purple-400 flex items-center gap-1">初始携带/信物</label>
                    <div class="flex gap-2 items-center">
                        <textarea v-model="rpgForm.item" :disabled="rpgLocks.item" :class="{'opacity-50 bg-gray-900': rpgLocks.item}" placeholder="一件有故事的随身物品..." class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none min-h-[50px]"></textarea>
                        <button @click="randomInput('item')" :disabled="rpgLocks.item" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg transition disabled:opacity-30 flex items-center justify-center"><i class="fas fa-dice"></i></button>
                        <button @click="rpgLocks.item = !rpgLocks.item" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.item ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.item ? 'fa-lock' : 'fa-lock-open'"></i></button>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-gray-400 flex items-center gap-1">开场白 (选填)</label>
                    <div class="flex gap-2 items-center">
                        <textarea v-model="rpgForm.opening" :disabled="rpgLocks.opening" :class="{'opacity-50 bg-gray-900': rpgLocks.opening}" placeholder="故事开始的第一句话..." class="flex-1 bg-gray-800 border border-gray-700 rounded-lg p-3 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none min-h-[50px]"></textarea>
                        <button @click="randomInput('opening')" :disabled="rpgLocks.opening" class="shrink-0 w-10 h-10 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 rounded-lg transition disabled:opacity-30 flex items-center justify-center"><i class="fas fa-dice"></i></button>
                        <button @click="rpgLocks.opening = !rpgLocks.opening" class="shrink-0 w-10 h-10 border border-gray-700 rounded-lg transition flex items-center justify-center" :class="rpgLocks.opening ? 'bg-red-900/20 text-red-500 border-red-500/50' : 'bg-gray-800 text-gray-500'"><i class="fas" :class="rpgLocks.opening ? 'fa-lock' : 'fa-lock-open'"></i></button>
                    </div>
                </div>
            </div>
            
            <div class="p-4 border-t border-gray-800 bg-gray-900 shrink-0 flex flex-col gap-3">
                 <div class="flex flex-col md:flex-row justify-between gap-3">
                    <div class="flex gap-2 items-center">
                        <button @click="exportRpgModule" class="px-3 py-2 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 hover:text-white rounded-lg text-xs font-bold transition"><i class="fas fa-save mr-1"></i>导出</button>
                        <label class="px-3 py-2 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 hover:text-white rounded-lg text-xs font-bold transition cursor-pointer flex items-center">
                            <i class="fas fa-folder-open mr-1"></i>加载
                            <input type="file" @change="importRpgModule" class="hidden" accept=".json">
                        </label>
                        <button @click="copyRpgInfo" class="px-3 py-2 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-400 hover:text-white rounded-lg text-xs font-bold transition"><i class="fas fa-copy mr-1"></i>复制文本</button>
                    </div>
                    <button @click="startRpgGame" class="bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white py-2 px-10 rounded-xl font-bold transition shadow-lg shadow-purple-900/30 flex justify-center items-center gap-2">
                        <i class="fas fa-play"></i> 开启世界
                    </button>
                </div>
            </div>
        </div>
    </div>
    

    <div v-if="showAdvSettings" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm overflow-y-auto">
        <div class="bg-gray-900 p-6 rounded-2xl w-full max-w-lg border border-gray-700 shadow-2xl my-auto">
            <div class="flex justify-between items-center mb-5">
                <h2 class="text-xl font-bold text-white"><i class="fas fa-sliders-h text-purple-500 mr-2"></i>引擎高级参数</h2>
                <button @click="showAdvSettings = false" class="text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button>
            </div>
            
            <div class="space-y-5">
                <div class="bg-[#1f1f28] p-4 rounded-xl border border-gray-700">
                    <div class="flex justify-between items-center mb-2">
                        <label class="text-sm font-bold text-gray-200 flex items-center gap-2"><i class="fas fa-history text-blue-400"></i> 携带历史记忆长度 (Context Limit)</label>
                        <span class="text-lg text-blue-400 font-mono font-bold">{{ activeProfile.memoryLength }}</span>
                    </div>
                    <input type="range" v-model="activeProfile.memoryLength" min="2" max="20" step="2" class="w-full accent-blue-500 mb-2">
                    <div class="text-[11px] text-gray-400 space-y-1.5 border-t border-gray-700 pt-2">
                        <p><strong>作用：</strong>严格限制每次 API 请求时，发送给大模型的对话条数（你发1句+AI回1句=2条）。</p>
                        <p><strong>原理：</strong>得益于本程序的“前端状态面板”架构，即便只传最近 2-6 条对话，AI 依然能通过读取面板来保持世界观和人设不崩塌。</p>
                        <p><strong>建议：</strong>日常跑团推荐设为 <strong>4 ~ 6</strong>。设置过高会导致 Token 消耗成倍暴涨。</p>
                    </div>
                </div>

                <div class="bg-[#1f1f28] p-4 rounded-xl border border-gray-700">
                    <div class="flex justify-between items-center mb-2">
                        <label class="text-sm font-bold text-gray-200 flex items-center gap-2"><i class="fas fa-brain text-pink-500"></i> 短期记忆 (STM) 归纳阈值</label>
                        <span class="text-lg text-pink-400 font-mono font-bold">{{ activeProfile.stmLength }}</span>
                    </div>
                    <input type="range" v-model="activeProfile.stmLength" min="3" max="15" step="1" class="w-full accent-pink-500 mb-2">
                    <div class="text-[11px] text-gray-400 space-y-1.5 border-t border-gray-700 pt-2">
                        <p><strong>作用：</strong>决定 AI 面板中“短期记忆”最多能容纳几条。超过此数值时，AI 会强制触发记忆压缩，将老旧的 STM 归纳进“长期记忆 (LTM)”中。</p>
                        <p><strong>建议：</strong>默认推荐 <strong>6</strong>。太低会导致 AI 频繁压缩记忆浪费算力，太高会导致短期记忆面板过长引起遗忘。</p>
                    </div>
                </div>

                <div class="bg-[#1f1f28] p-4 rounded-xl border border-gray-700">
                    <div class="flex justify-between items-center mb-2">
                        <label class="text-sm font-bold text-gray-200 flex items-center gap-2"><i class="fas fa-fire text-orange-500"></i> RPG 创造力 (Temperature)</label>
                        <span class="text-lg text-orange-400 font-mono font-bold">{{ activeProfile.tempRpg }}</span>
                    </div>
                    <input type="range" v-model="activeProfile.tempRpg" min="0" max="2" step="0.1" class="w-full accent-orange-500 mb-2">
                    <div class="text-[11px] text-gray-400 space-y-1.5 border-t border-gray-700 pt-2">
                        <p><strong>作用：</strong>决定大模型在“RPG跑团模式”下生成文本的随机性、发散程度与词汇华丽度。</p>
                        <p><strong>建议：</strong>对于小说/跑团推演，推荐设为 <strong>0.8 ~ 1.0</strong> 之间。过高(>1.2)易发散幻觉，过低(<0.5)回复如机械般死板。</p>
                    </div>
                </div>

                <div class="bg-[#1f1f28] p-4 rounded-xl border border-gray-700">
                    <div class="flex justify-between items-center mb-2">
                        <label class="text-sm font-bold text-gray-200 flex items-center gap-2"><i class="fas fa-comment-dots text-green-500"></i> 日常聊天严谨度 (Temperature)</label>
                        <span class="text-lg text-green-400 font-mono font-bold">{{ activeProfile.tempChat }}</span>
                    </div>
                    <input type="range" v-model="activeProfile.tempChat" min="0" max="2" step="0.1" class="w-full accent-green-500 mb-2">
                    <div class="text-[11px] text-gray-400 space-y-1.5 border-t border-gray-700 pt-2">
                        <p><strong>作用：</strong>决定左侧蓝色“普通对话模式”下的随机性。</p>
                        <p><strong>建议：</strong>日常问答、写代码或查资料，需要逻辑严密，推荐设为 <strong>0.5 ~ 0.6</strong>。</p>
                    </div>
                </div>
            </div>

            <div class="mt-6 flex justify-end">
                <button @click="showAdvSettings = false" class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-xl font-bold shadow-lg shadow-purple-900/50 transition">完成设定</button>
            </div>
        </div>
    </div>

    <div v-if="showSettings" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
        <div class="bg-gray-900 p-6 rounded-2xl w-full max-w-md border border-gray-700 shadow-2xl">
            <div class="flex justify-between items-center mb-5">
                <h2 class="text-lg font-bold text-white"><i class="fas fa-server text-blue-500 mr-2"></i>API 节点管理</h2>
                <button @click="showSettings = false" class="text-gray-400 hover:text-white"><i class="fas fa-times"></i></button>
            </div>
            
            <div class="bg-gray-800 p-3 rounded-lg border border-gray-700 mb-4">
                <label class="text-xs font-bold text-gray-400 block mb-2">配置切换</label>
                <div class="flex gap-2">
                    <select v-model="activeProfileId" class="flex-1 bg-gray-900 border border-gray-600 rounded-lg p-2 text-sm text-white outline-none">
                        <option v-for="profile in profiles" :key="profile.id" :value="profile.id">{{ profile.name }}</option>
                    </select>
                    <button @click="addNewProfile" class="bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-lg text-sm transition"><i class="fas fa-plus"></i></button>
                    <button @click="deleteActiveProfile" :disabled="profiles.length <= 1" class="bg-red-600 hover:bg-red-700 disabled:opacity-50 text-white px-3 py-2 rounded-lg text-sm transition"><i class="fas fa-trash"></i></button>
                </div>
            </div>

            <div v-if="activeProfile" class="space-y-4 border-t border-gray-700 pt-4">
                <div><label class="text-xs font-bold text-gray-500 block mb-1">名称</label><input v-model="activeProfile.name" class="w-full bg-gray-950 border border-gray-700 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500"></div>
                <div><label class="text-xs font-bold text-gray-500 block mb-1">Base URL</label><input v-model="activeProfile.baseUrl" placeholder="https://api.openai.com/v1" class="w-full bg-gray-950 border border-gray-700 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500"></div>
                <div><label class="text-xs font-bold text-gray-500 block mb-1">API Key</label><input v-model="activeProfile.apiKey" type="password" class="w-full bg-gray-950 border border-gray-700 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500"></div>
                <div><label class="text-xs font-bold text-gray-500 block mb-1">Model Name</label><input v-model="activeProfile.model" class="w-full bg-gray-950 border border-gray-700 rounded-lg p-3 text-sm text-white outline-none focus:border-blue-500"></div>
                
                <div class="border-t border-gray-700 pt-4 mt-4 flex gap-3">
                    <button @click="exportProfiles" class="flex-1 bg-gray-700 hover:bg-gray-600 text-gray-300 py-2 rounded-lg text-xs font-bold transition flex items-center justify-center gap-1"><i class="fas fa-download"></i> 导出全部</button>
                    <label class="flex-1 bg-gray-700 hover:bg-gray-600 text-gray-300 py-2 rounded-lg text-xs font-bold transition cursor-pointer flex items-center justify-center gap-1">
                        <i class="fas fa-upload"></i> 导入替换
                        <input type="file" @change="importProfiles" class="hidden" accept=".json">
                    </label>
                </div>
                
                <div class="border-t border-gray-700 pt-3 mt-3">
                    <label class="text-xs font-bold text-gray-400 block mb-1">一键粘贴配置 (名称,URL,Key,模型)</label>
                    <div class="flex gap-2">
                        <textarea v-model="quickPasteConfig" placeholder="一行一条，可粘贴多行&#10;格式: Name,https://...,sk-...,gpt-4" rows="4" class="flex-1 bg-gray-950 border border-gray-700 rounded-lg p-2 text-xs text-gray-300 outline-none resize-y"></textarea>
                        <button @click="applyQuickPaste" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded-lg text-xs font-bold whitespace-nowrap">添加</button>
                    </div>
                </div>
            </div>
            <div class="mt-6"><button @click="showSettings = false" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-bold w-full">完成</button></div>
        </div>
    </div>
</div>

    <script src="/static/default_prompts.js"></script>
    <script src="/static/random_libs.js"></script>
    <script src="/static/script.js"></script>

</body>
</html>